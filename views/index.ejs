<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CloudBees Unify Playground</title>
    <style>
      :root {
        --slate: #334155;
        --emerald: #059669;
        --amber: #d97706;
        --rose: #e11d48;
        --bg: #f8fafc;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --border: #cbd5e1;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      .wrap {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 20px 48px;
      }

      .hero,
      .grid > section {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
      }

      .hero h1 {
        margin-top: 0;
        margin-bottom: 12px;
      }

      .subtitle {
        color: var(--muted);
        line-height: 1.5;
      }

      .callout {
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 12px;
        color: white;
        font-weight: bold;
      }

      .callout.slate { background: var(--slate); }
      .callout.emerald { background: var(--emerald); }
      .callout.amber { background: var(--amber); }
      .callout.rose { background: var(--rose); }

      .grid {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
      }

      ul {
        padding-left: 20px;
        line-height: 1.6;
      }

      code {
        background: #e2e8f0;
        border-radius: 6px;
        padding: 2px 6px;
      }

      .hint {
        margin-top: 18px;
        font-size: 14px;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="hero">
        <h1>
          Hello from CloudBees Unify Playground
          <% if (flags.showExcitedGreeting) { %>
            🚀
          <% } %>
        </h1>
        <p class="subtitle">
          This tiny app is meant to help you learn CloudBees Unify with one repo. It gives you a GitHub Actions workflow for repo integration and a few feature flags you can toggle in the UI.
        </p>

        <div class="callout <%= flags.greetingColor %>">
          Release message: <%= flags.releaseMessage %>
        </div>

        <p class="hint">
          Try different contexts with
          <code>?email=jade@example.com&amp;plan=pro&amp;region=us</code>
        </p>
      </section>

      <div class="grid">
        <section>
          <h2>Current request context</h2>
          <ul>
            <li><strong>email:</strong> <%= context.email %></li>
            <li><strong>plan:</strong> <%= context.plan %></li>
            <li><strong>region:</strong> <%= context.region %></li>
            <li><strong>repo:</strong> <%= repoName %></li>
            <li><strong>commit:</strong> <%= commitSha %></li>
          </ul>
        </section>

        <section>
          <h2>Flag evaluations</h2>
          <ul>
            <li><strong>showExcitedGreeting:</strong> <%= flags.showExcitedGreeting %></li>
            <li><strong>showDebugPanel:</strong> <%= flags.showDebugPanel %></li>
            <li><strong>greetingColor:</strong> <%= flags.greetingColor %></li>
            <li><strong>releaseMessage:</strong> <%= flags.releaseMessage %></li>
          </ul>
        </section>

        <% if (flags.showDebugPanel) { %>
          <section>
            <h2>SDK status</h2>
            <ul>
              <li><strong>initialized:</strong> <%= sdkState.initialized %></li>
              <li><strong>mode:</strong> <%= sdkState.mode %></li>
              <li><strong>error:</strong> <%= sdkState.error || 'none' %></li>
            </ul>
          </section>
        <% } %>
      </div>
    </main>
  </body>
</html>
